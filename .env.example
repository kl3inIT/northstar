# Copy to .env and fill in. Loaded via spring.config.import (optional).
OPENAI_API_KEY=sk-...

# Single-user web login. Generate a real hash locally; do not store plaintext.
NORTHSTAR_AUTH_ENABLED=true
NORTHSTAR_AUTH_USERNAME=your-username
NORTHSTAR_AUTH_PASSWORD_HASH={bcrypt}replace-with-a-real-bcrypt-hash
NORTHSTAR_COOKIE_SECURE=false

# Native mobile token auth. Generate a secret with: openssl rand -base64 32
# Keep disabled until NORTHSTAR_MOBILE_AUTH_JWT_SECRET is configured.
NORTHSTAR_MOBILE_AUTH_ENABLED=false
NORTHSTAR_MOBILE_AUTH_JWT_SECRET=
# Optional, explicit CORS origin for the local Flutter Web review server.
NORTHSTAR_MOBILE_AUTH_WEB_PREVIEW_ORIGIN=
