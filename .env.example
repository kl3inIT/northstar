# Copy to .env and fill in. Loaded via spring.config.import (optional).
OPENAI_API_KEY=sk-...
# Generate once with: openssl rand -base64 32
NORTHSTAR_AI_CREDENTIAL_KEY=

# Optional Morning Brief sources. GitHub works anonymously at a lower rate;
# Firecrawl stays disabled unless its server-side key is present.
GITHUB_TOKEN=
FIRECRAWL_API_KEY=

# Optional speech assessment. The key is region-bound.
NORTHSTAR_SPEECH_PROVIDER=azure
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastasia

# Single-user web login. Set false only on a trusted development machine to
# bypass the login screen. Generate a real hash locally; do not store plaintext.
NORTHSTAR_AUTH_ENABLED=true
NORTHSTAR_AUTH_USERNAME=your-username
NORTHSTAR_AUTH_PASSWORD_HASH={bcrypt}replace-with-a-real-bcrypt-hash
# Keep false only for local HTTP; production behind HTTPS must set this to true.
NORTHSTAR_COOKIE_SECURE=false

# Native mobile token auth. Generate a secret with: openssl rand -base64 32
# Keep disabled until NORTHSTAR_MOBILE_AUTH_JWT_SECRET is configured.
NORTHSTAR_MOBILE_AUTH_ENABLED=false
NORTHSTAR_MOBILE_AUTH_JWT_SECRET=
# Browser-only CORS allowlist. Leave empty for native iOS/Android and same-origin
# web deployments. Use exact comma-separated origins; never use `*`.
# Example: http://127.0.0.1:7357,https://mobile-preview.example.com
NORTHSTAR_CORS_ALLOWED_ORIGINS=
