# =============================================================================
# Northstar — SERVER environment template.
#
# On the VPS: copy to /apps/northstar/.env (repo root, gitignored) and fill in.
# Consumed twice, zero-mail style: compose interpolation (--env-file .env) AND
# injected into the api/mcp containers (env_file: ../.env).
# =============================================================================

# ── Postgres (infra compose) ─────────────────────────────────────────────────
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=northstar
POSTGRES_USER=northstar
# POSTGRES_IMAGE=pgvector/pgvector:pg18
# POSTGRES_VOLUME_NAME=northstar_postgres_data

# ── OpenAI (capture, assistant chat, alignment, realtime dictation) ──────────
OPENAI_API_KEY=sk-CHANGE_ME
# NORTHSTAR_CAPTURE_MODEL=gpt-5.5
# AES-256 key used only for runtime gateway credentials stored from Settings.
# Generate once with: openssl rand -base64 32. Keep it stable across deployments.
NORTHSTAR_AI_CREDENTIAL_KEY=CHANGE_ME

# ── Morning Brief source adapters ────────────────────────────────────────────
# Optional: raises GitHub's public REST rate limit from 60 to 5,000/hour.
GITHUB_TOKEN=
# Optional: enables bounded Firecrawl fallback; public sources run without it.
FIRECRAWL_API_KEY=

# ── Azure Speech pronunciation assessment ──────────────────────────────────
NORTHSTAR_SPEECH_PROVIDER=azure
AZURE_SPEECH_KEY=CHANGE_ME
AZURE_SPEECH_REGION=eastasia

# ── Authentication ───────────────────────────────────────────────────────────
NORTHSTAR_AUTH_ENABLED=true
NORTHSTAR_AUTH_USERNAME=CHANGE_ME
NORTHSTAR_AUTH_PASSWORD_HASH=CHANGE_ME
NORTHSTAR_COOKIE_SECURE=true
# Generate with: openssl rand -base64 32
NORTHSTAR_MOBILE_AUTH_ENABLED=false
NORTHSTAR_MOBILE_AUTH_JWT_SECRET=
NORTHSTAR_MOBILE_AUTH_WEB_PREVIEW_ORIGIN=

# ── Timezone ─────────────────────────────────────────────────────────────────
# The user's IANA zone. The app derives "today"/"this week" from the container's
# system zone, so this must be the USER's zone, not the VPS default (UTC).
# TZ=Asia/Ho_Chi_Minh

# ── Image overrides — leave empty for local builds; deploy workflow fills these ──
NORTHSTAR_API_IMAGE=
NORTHSTAR_WEB_IMAGE=
NORTHSTAR_MCP_IMAGE=
